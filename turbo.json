{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "BASE_REF",
    "CHANGED_FILES",
    "CHANGED_FILES_FILE",
    "CHAT_REALTIME_TOKEN_SECRET",
    "DOCKER_WEB_BUILDKIT_PRUNE_KEEP_STORAGE",
    "DOCKER_WEB_BUILDKIT_PRUNE_MODE",
    "DOCKER_WEB_BUILDKIT_PRUNE_UNTIL",
    "DOCKER_WEB_NODE_BINARY",
    "DOCKER_WEB_SUPABASE_START_EXCLUDE",
    "E2E_DOCKER_BUILDKIT_PRUNE_AFTER_BUILD",
    "E2E_DOCKER_BUILDKIT_PRUNE_MODE",
    "E2E_SUPABASE_START_EXCLUDE",
    "GH_TOKEN",
    "GITHUB_API_URL",
    "GITHUB_ENV",
    "GITHUB_EVENT_NAME",
    "GITHUB_EVENT_PATH",
    "GITHUB_OUTPUT",
    "GITHUB_REF",
    "GITHUB_REF_NAME",
    "GITHUB_REPOSITORY",
    "GITHUB_RUN_ATTEMPT",
    "GITHUB_RUN_ID",
    "GITHUB_SERVER_URL",
    "GITHUB_SHA",
    "GITHUB_TOKEN",
    "GITHUB_WORKFLOW_REF",
    "HEAD_REF",
    "MODE",
    "NODE_OPTIONS",
    "PLATFORM_CRON_CONTROL_DIR",
    "PLATFORM_CRON_MONITORING_DIR",
    "PLATFORM_DEPLOYMENT_STAMP",
    "PLATFORM_STRESS_TEST_CONTROL_DIR",
    "PLATFORM_STRESS_TEST_MONITORING_DIR",
    "PLATFORM_WEB_CRON_COMPOSE_FILE",
    "PORT",
    "PORTLESS_URL",
    "RUNNER_TEMP",
    "SUPABASE_SERVICE_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "TURBO_API",
    "TURBO_REMOTE_CACHE_SIGNATURE_KEY",
    "TURBO_TEAM",
    "TURBO_TOKEN",
    "WORKFLOW_NAME"
  ],
  "globalEnv": [
    "INTERNAL_TRIGGER_SECRET_KEY",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "SHOW_TAILWIND_INDICATOR",
    "NEXT_PUBLIC_VERCEL_ENV",
    "PUB_CACHE",
    "SUPABASE_SECRET_KEY",
    "LOCALAPPDATA",
    "MODAL_TOKEN_SECRET",
    "ANTHROPIC_API_KEY",
    "MODAL_TOKEN_ID",
    "OPENAI_API_KEY",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "GOOGLE_REDIRECT_URI",
    "GOOGLE_GENERATIVE_AI_API_KEY",
    "GOOGLE_VERTEX_PROJECT",
    "GOOGLE_VERTEX_LOCATION",
    "GOOGLE_VERTEX_EMAIL",
    "GOOGLE_VERTEX_CLIENT_ID",
    "GOOGLE_VERTEX_PRIVATE_KEY",
    "GOOGLE_VERTEX_PRIVATE_KEY_ID",
    "GOOGLE_APPLICATION_CREDENTIALS",
    "DEFAULT_AI_MODEL",
    "CF_ACCOUNT_ID",
    "CF_API_TOKEN",
    "AURORA_EXTERNAL_URL",
    "AURORA_EXTERNAL_WSID",
    "SCRAPER_URL",
    "BASE_URL",
    "API_URL",
    "APP_COORDINATION_TOKEN_SECRET",
    "TUTURUUU_APP_COORDINATION_SECRET",
    "HIVE_APP_URL",
    "HIVE_DATABASE_URL",
    "HIVE_REALTIME_HTTP_URL",
    "HIVE_REALTIME_TOKEN_SECRET",
    "HIVE_REALTIME_URL",
    "INTERNAL_WEB_API_ORIGIN",
    "MEET_APP_URL",
    "MEET_REALTIME_TOKEN_SECRET",
    "MEET_REALTIME_URL",
    "NEXT_PUBLIC_HIVE_APP_URL",
    "NEXT_PUBLIC_HIVE_REALTIME_URL",
    "NEXT_PUBLIC_MEET_APP_URL",
    "NEXT_PUBLIC_MEET_REALTIME_URL",
    "NEXT_PUBLIC_WEB_APP_URL",
    "WEB_APP_URL",
    "CLOUDFLARE_REALTIME_API_BASE_URL",
    "CLOUDFLARE_REALTIME_APP_ID",
    "CLOUDFLARE_REALTIME_APP_SECRET",
    "ANALYZE",
    "NODE_ENV",
    "TRIGGER_SECRET_KEY",
    "POLAR_ACCESS_TOKEN",
    "POLAR_WEBHOOK_SECRET",
    "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
    "USERPROFILE"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "$TURBO_ROOT$/.env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "dist/**",
        ".turbo/tsconfig.tsbuildinfo"
      ]
    },
    "build:docker": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", "$TURBO_ROOT$/.env*"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "dist/**",
        ".turbo/tsconfig.tsbuildinfo"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@tuturuuu/types#dev": {
      "cache": false,
      "persistent": true
    },
    "@tuturuuu/hive#serve:hive": {
      "dependsOn": ["^build", "build"],
      "cache": false,
      "persistent": true
    },
    "@tuturuuu/hive-realtime#serve:hive-realtime": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "env": ["CHECK_DETAILS"]
    },
    "test:e2e": {
      "cache": false
    },
    "test:watch": {
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build", "^type-check"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/messages/*.json",
        "bun.lock",
        "package.json"
      ],
      "outputs": [
        "tsconfig.tsbuildinfo",
        "tsconfig.build.tsbuildinfo",
        "dist/tsconfig.tsbuildinfo",
        ".turbo/tsconfig.tsbuildinfo",
        ".next/cache/.tsbuildinfo"
      ]
    },
    "dart-format": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "pubspec.yaml",
        "pubspec.lock",
        "analysis_options.yaml"
      ],
      "outputs": []
    },
    "flutter-analyze": {
      "dependsOn": ["dart-format"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "pubspec.yaml",
        "pubspec.lock",
        "analysis_options.yaml"
      ],
      "outputs": []
    },
    "flutter-test": {
      "dependsOn": ["flutter-analyze"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "pubspec.yaml",
        "pubspec.lock",
        "analysis_options.yaml"
      ],
      "outputs": []
    },
    "i18n:check": {
      "inputs": [
        "apps/*/messages/**/*.json",
        "apps/*/src/**/*.{ts,tsx,js,jsx}"
      ],
      "outputs": []
    },
    "i18n:sort:check": {
      "inputs": ["apps/*/messages/**/*.json", "scripts/i18n-sort.js"],
      "outputs": []
    }
  }
}
