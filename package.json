{
  "name": "hub",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "buildx": "turbo test lint build",
    "clean": "rm bun.lock && bunx npkill --delete-all -y",
    "dev": "turbo run dev --continue",
    "dev:docs": "cd apps/docs && mintlify dev",
    "dev:nl": "turbo run dev -F @ncthub/neo-league",
    "dev:web": "turbo run dev -F @ncthub/web",
    "devx": "bun sb:stop && bun sb:start && bun dev",
    "devx:nl": "bun sb:stop && bun sb:start && bun dev:nl",
    "devx:web": "bun sb:stop && bun sb:start && bun dev:web",
    "devrs": "bun sb:stop && bun sb:start && bun sb:reset && bun dev",
    "devrs:nl": "bun sb:stop && bun sb:start && bun sb:reset && bun dev:nl",
    "devrs:web": "bun sb:stop && bun sb:start && bun sb:reset && bun dev:web",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "type-check": "turbo run type-check",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format-and-lint": "biome check",
    "format-and-lint:fix": "biome check --write",
    "redis:start": "cd apps/redis && bun redis:start",
    "redis:stop": "cd apps/redis && bun redis:stop",
    "stop": "cd apps/db && bun sb:stop",
    "sb:status": "cd apps/db && bun sb:status",
    "sb:start": "cd apps/db && bun sb:start",
    "sb:stop": "cd apps/db && bun sb:stop",
    "sb:sync": "cd apps/db && bun sb:sync",
    "sb:pull": "cd apps/db && bun sb:pull && bun sb:typegen",
    "sb:push": "cd apps/db && bun sb:push && bun sb:typegen",
    "sb:link": "cd apps/db && bun sb:link",
    "sb:linkpush": "cd apps/db && bun sb:linkpush",
    "sb:reset": "cd apps/db && bun sb:reset && bun sb:typegen",
    "sb:diff": "cd apps/db && bun sb:up && bun sb:diff && bun sb:typegen",
    "sb:new": "cd apps/db && bun sb:new",
    "sb:up": "cd apps/db && bun sb:up && bun sb:typegen",
    "sb:typegen": "cd apps/db && bun sb:typegen",
    "ui:add": "bun --filter ui ui:add",
    "ui:diff": "bun --filter ui ui:diff",
    "update-all": "bun ./scripts/package-update.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@ncthub/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.2",
    "turbo": "^2.9.3",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": ["apps/*", "packages/*"],
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "@vercel/speed-insights",
    "canvas",
    "core-js",
    "cytoscape",
    "esbuild",
    "puppeteer",
    "sharp",
    "supabase",
    "unrs-resolver"
  ]
}
