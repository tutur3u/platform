{
  "name": "tuturuuu",
  "version": "0.12.0",
  "description": "Official TypeScript/JavaScript SDK for the Tuturuuu platform",
  "license": "MIT",
  "author": "Tuturuuu",
  "homepage": "https://tuturuuu.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/tutur3u/platform",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/tutur3u/platform/issues"
  },
  "keywords": ["tuturuuu", "sdk", "api"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ttr": "./dist/cli/index.js",
    "tuturuuu": "./dist/cli/index.js",
    "tutur3u": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "bun": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./storage": {
      "types": "./dist/storage.d.ts",
      "bun": "./dist/storage.js",
      "import": "./dist/storage.js",
      "require": "./dist/storage.js",
      "default": "./dist/storage.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "bun": "./dist/types.js",
      "import": "./dist/types.js",
      "require": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "bun": "./dist/errors.js",
      "import": "./dist/errors.js",
      "require": "./dist/errors.js",
      "default": "./dist/errors.js"
    },
    "./external-projects": {
      "types": "./dist/external-projects.d.ts",
      "bun": "./dist/external-projects.js",
      "import": "./dist/external-projects.js",
      "require": "./dist/external-projects.js",
      "default": "./dist/external-projects.js"
    },
    "./external-projects/public-assets": {
      "types": "./dist/external-projects-public-assets-node.d.ts",
      "bun": "./dist/external-projects-public-assets-node.js",
      "import": "./dist/external-projects-public-assets-node.js",
      "require": "./dist/external-projects-public-assets-node.js",
      "default": "./dist/external-projects-public-assets-node.js"
    },
    "./epm": {
      "types": "./dist/epm.d.ts",
      "bun": "./dist/epm.js",
      "import": "./dist/epm.js",
      "require": "./dist/epm.js",
      "default": "./dist/epm.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "bun": "./dist/platform.js",
      "import": "./dist/platform.js",
      "require": "./dist/platform.js",
      "default": "./dist/platform.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch --incremental",
    "ttr": "bun src/cli/index.ts",
    "type-check": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo tsconfig.build.tsbuildinfo",
    "prepack": "bun run clean && bun run build",
    "prepublishOnly": "bun run test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tuturuuu/devbox": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/node": "^26.0.1",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.14"
}
