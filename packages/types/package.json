{
  "name": "@tuturuuu/types",
  "license": "MIT",
  "version": "0.15.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tutur3u/platform",
    "directory": "packages/types"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsc --project tsconfig.build.json --watch --incremental",
    "type-check": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "dependencies": {
    "@tiptap/react": "3.27.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "typescript": "7.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk.d.ts",
      "import": "./dist/sdk.js",
      "require": "./dist/sdk.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js",
      "require": "./dist/primitives/index.js"
    },
    "./primitives/*": {
      "types": "./dist/primitives/*.d.ts",
      "import": "./dist/primitives/*.js",
      "require": "./dist/primitives/*.js"
    },
    "./db": {
      "types": "./dist/db.d.ts",
      "import": "./dist/db.js",
      "require": "./dist/db.js"
    },
    "./supabase": {
      "types": "./dist/supabase.d.ts",
      "import": "./dist/supabase.js",
      "require": "./dist/supabase.js"
    },
    "./tiptap": {
      "types": "./dist/tiptap.d.ts",
      "import": "./dist/tiptap.js",
      "require": "./dist/tiptap.js"
    }
  },
  "packageManager": "bun@1.3.14"
}
