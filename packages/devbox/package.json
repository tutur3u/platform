{
  "name": "@tuturuuu/devbox",
  "license": "MIT",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/tutur3u/platform",
    "directory": "packages/devbox"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo --project tsconfig.json",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "prepack": "bun run clean && bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsgo --project tsconfig.typecheck.json"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "packageManager": "bun@1.3.14",
  "devDependencies": {
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260607.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
