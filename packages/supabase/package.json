{
  "name": "@tuturuuu/supabase",
  "version": "0.3.3",
  "description": "Supabase client and utilities for Next.js applications with SSR support, cookie handling, and TypeScript type safety",
  "keywords": [
    "supabase",
    "nextjs",
    "ssr",
    "database",
    "authentication",
    "postgresql",
    "realtime",
    "typescript"
  ],
  "license": "MIT",
  "author": "Tuturuuu",
  "repository": {
    "type": "git",
    "url": "https://github.com/tutur3u/platform",
    "directory": "packages/supabase"
  },
  "bugs": {
    "url": "https://github.com/tutur3u/platform/issues"
  },
  "homepage": "https://github.com/tutur3u/platform/tree/main/packages/supabase#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "src", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./next/client": {
      "types": "./dist/next/client.d.ts",
      "bun": "./src/next/client.ts",
      "default": "./dist/next/client.js"
    },
    "./next/auth-browser": {
      "types": "./dist/next/auth-browser.d.ts",
      "default": "./dist/next/auth-browser.js"
    },
    "./next/auth-session-user": {
      "types": "./dist/next/auth-session-user.d.ts",
      "bun": "./src/next/auth-session-user.ts",
      "default": "./dist/next/auth-session-user.js"
    },
    "./next/common": {
      "types": "./dist/next/common.d.ts",
      "bun": "./src/next/common.ts",
      "default": "./dist/next/common.js"
    },
    "./next/proxy": {
      "types": "./dist/next/proxy.d.ts",
      "bun": "./src/next/proxy.ts",
      "default": "./dist/next/proxy.js"
    },
    "./next/realtime": {
      "types": "./dist/next/realtime.d.ts",
      "bun": "./src/next/realtime.ts",
      "default": "./dist/next/realtime.js"
    },
    "./next/realtime-browser": {
      "types": "./dist/next/realtime-browser.d.ts",
      "default": "./dist/next/realtime-browser.js"
    },
    "./next/realtime-log-provider": {
      "types": "./dist/next/realtime-log-provider.d.ts",
      "bun": "./src/next/realtime-log-provider.tsx",
      "default": "./dist/next/realtime-log-provider.js"
    },
    "./next/server": {
      "types": "./dist/next/server.d.ts",
      "bun": "./src/next/server.ts",
      "default": "./dist/next/server.js"
    },
    "./next/user": {
      "types": "./dist/next/user.d.ts",
      "bun": "./src/next/user.ts",
      "default": "./dist/next/user.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo --build",
    "dev": "tsgo --build --watch",
    "type-check": "tsgo --project tsconfig.typecheck.json",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "bun run clean && bun run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tuturuuu/types": "workspace:*",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@typescript/native-preview": "^7.0.0-dev.20260612.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "next": ">=16.2.9",
    "react": ">=19.2.7",
    "react-dom": ">=19.2.7"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=18.0.0"
  }
}
