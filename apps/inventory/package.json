{
  "name": "@tuturuuu/inventory",
  "version": "0.13.0",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsc-build.js --build",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7815} --turbopack",
    "devx": "bun sb:stop && bun sb:start && bun dev",
    "devrs": "bun sb:stop && bun sb:start && bun sb:reset && bun dev",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7815 --turbopack",
    "stop": "cd ../database && bun sb:stop",
    "sb:status": "cd ../database && bun sb:status",
    "sb:start": "cd ../database && bun sb:start",
    "sb:stop": "cd ../database && bun sb:stop",
    "sb:sync": "cd ../database && bun sb:sync",
    "sb:reset": "cd ../database && bun sb:reset",
    "sb:diff": "cd ../database && bun sb:diff",
    "sb:new": "cd ../database && bun sb:new",
    "sb:up": "cd ../database && bun sb:up",
    "sb:typegen": "cd ../database && bun sb:typegen",
    "ui:add": "bunx shadcn-ui@latest add",
    "ui:diff": "bunx shadcn-ui@latest diff"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "inventory.tuturuuu",
    "script": "dev:app"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.8",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@tuturuuu/ai": "workspace:*",
    "@tuturuuu/apis": "workspace:*",
    "@tuturuuu/auth": "workspace:*",
    "@tuturuuu/finance-core": "workspace:*",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/inventory-core": "workspace:*",
    "@tuturuuu/offline": "workspace:*",
    "@tuturuuu/payment": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/storage-core": "workspace:*",
    "@tuturuuu/supabase": "workspace:*",
    "@tuturuuu/turnstile": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "ai": "^7.0.16",
    "next": "^16.3.0-preview.5",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "nuqs": "^2.9.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.2",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "postcss": "^8.5.16",
    "typescript": "7.0.2"
  }
}
