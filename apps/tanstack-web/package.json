{
  "name": "@tuturuuu/tanstack-web",
  "version": "0.6.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "type-check": "node ../../scripts/run-tsc-build.js --noEmit -p tsconfig.json",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- vite dev --host 0.0.0.0 --port ${PORT:-7824}",
    "build": "vite build && bun type-check",
    "build:docker": "vite build && bun type-check",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview --host 0.0.0.0 --port ${PORT:-7824}",
    "preview:cloudflare": "wrangler dev",
    "deploy:cloudflare": "bun run build && wrangler deploy",
    "deploy:cloudflare:dry-run": "bun run build && wrangler deploy --dry-run",
    "cf-typegen": "wrangler types",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "tanstack.tuturuuu",
    "script": "dev:app"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-email/render": "^2.0.9",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/react": "3.27.1",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/offline": "workspace:*",
    "@tuturuuu/payment": "workspace:*",
    "@tuturuuu/transactional": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "date-fns": "4.4.0",
    "dayjs": "^1.11.20",
    "jotai": "^2.20.1",
    "moment": "^2.30.1",
    "next-themes": "^0.4.6",
    "nuqs": "^2.9.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-papaparse": "^4.4.0",
    "use-intl": "^4.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.4",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "next-intl": "^4.13.1",
    "nitro": "^3.0.260610-beta",
    "tailwindcss": "^4.3.2",
    "typescript": "7.0.1-rc",
    "vite": "^8.1.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.9",
    "wrangler": "^4.106.0"
  }
}
