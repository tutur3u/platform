{
  "name": "@tuturuuu/infrastructure",
  "version": "0.10.0",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsc-build.js --build",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7823} --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7823 --turbopack",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "infra.tuturuuu",
    "script": "dev:app"
  },
