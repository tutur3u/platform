    "@octokit/auth-app": "^8.2.0",
    "@react-email/render": "^2.1.0",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/react": "3.28.0",
    "@tuturuuu/ai": "workspace:*",
