{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && bun turbo:local run build --filter=@tuturuuu/infrastructure",
  "installCommand": "bunx bun@1.3.14 install --frozen-lockfile",
  "git": {
    "deploymentEnabled": false
  },
  "github": {
    "enabled": false
  },
  "crons": [
    {
      "path": "/api/cron/infrastructure/sample-resources",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/infrastructure/docker-recovery-alerts",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/infrastructure/sync-trust-cache",
      "schedule": "*/10 * * * *"
    }
  ]
}
