{
  "name": "@tuturuuu/chat",
  "version": "0.11.0",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsc-build.js --build",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7821} --turbopack",
    "build": "next build --turbopack",
    "build:docker": "NODE_OPTIONS='--max-old-space-size=8192 --experimental-require-module' next build --turbopack",
    "serve:chat": "NODE_OPTIONS='--max-http-header-size=65536 --experimental-require-module' next start -p 7821",
    "start": "NODE_OPTIONS='--max-http-header-size=65536' next start -p 7821",
    "preview": "next build --turbopack && NODE_OPTIONS='--max-http-header-size=65536' next start -p 7821",
    "test": "vitest run",
    "test:watch": "vitest",
    "stop": "cd ../database && bun sb:stop",
    "sb:status": "cd ../database && bun sb:status",
    "sb:start": "cd ../database && bun sb:start",
    "sb:stop": "cd ../database && bun sb:stop",
    "sb:sync": "cd ../database && bun sb:sync",
    "sb:reset": "cd ../database && bun sb:reset",
    "sb:diff": "cd ../database && bun sb:diff",
    "sb:new": "cd ../database && bun sb:new",
    "sb:up": "cd ../database && bun sb:up",
    "sb:typegen": "cd ../database && bun sb:typegen"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "chat.tuturuuu",
    "script": "dev:app"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.13",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.6",
    "@tuturuuu/auth": "workspace:*",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/offline": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/supabase": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "negotiator": "^1.0.0",
    "next": "^16.3.0-preview.6",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@tanstack/react-query-devtools": "^5.101.4",
    "@testing-library/react": "^16.3.2",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.20",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
