{
  "name": "@tuturuuu/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "NODE_OPTIONS='--experimental-require-module' node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7803} --turbopack",
    "devx": "bun sb:stop && bun sb:start && bun dev",
    "devrs": "bun sb:stop && bun sb:start && bun sb:reset && bun dev",
    "build": "NODE_OPTIONS='--max-old-space-size=8192 --experimental-require-module' next build --turbopack",
    "build:docker": "bun ../../scripts/run-web-docker-next-build.js",
    "start": "portless --script start:app",
    "start:app": "NODE_OPTIONS='--experimental-require-module' node ../../scripts/portless-dev-banner.js -- next start -p ${PORT:-7803}",
    "serve:web": "NODE_OPTIONS='--experimental-require-module' next start -p 7803",
    "preview": "NODE_OPTIONS='--max-old-space-size=8192 --experimental-require-module' next build --turbopack && NODE_OPTIONS='--experimental-require-module' next start -p 7803 --turbopack",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node ../../scripts/run-web-e2e-docker.js",
    "test:e2e:ui": "node ../../scripts/run-web-e2e-docker.js --ui",
    "type-check": "node ../../scripts/run-tsc-build.js --build",
    "stop": "cd ../database && bun sb:stop",
    "sb:status": "cd ../database && bun sb:status",
    "sb:start": "cd ../database && bun sb:start",
    "sb:stop": "cd ../database && bun sb:stop",
    "sb:sync": "cd ../database && bun sb:sync",
    "sb:reset": "cd ../database && bun sb:reset",
    "sb:diff": "cd ../database && bun sb:diff",
    "sb:new": "cd ../database && bun sb:new",
    "sb:up": "cd ../database && bun sb:up",
    "sb:typegen": "cd ../database && bun sb:typegen",
    "sbr:status": "cd ../database && bun sbr:status",
    "sbr:start": "cd ../database && bun sbr:start",
    "sbr:stop": "cd ../database && bun sbr:stop",
    "sbr:sync": "cd ../database && bun sbr:sync",
    "sbr:reset": "cd ../database && bun sbr:reset",
    "sbr:diff": "cd ../database && bun sbr:diff",
    "sbr:new": "cd ../database && bun sbr:new",
    "sbr:up": "cd ../database && bun sbr:up",
    "sbr:typegen": "cd ../database && bun sbr:typegen",
    "ui:add": "bunx shadcn-ui@latest add",
    "ui:diff": "bunx shadcn-ui@latest diff"
  },
