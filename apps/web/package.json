    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "type-check": "node ../../scripts/run-tsgo-build.js --build",
    "stop": "cd ../database && bun sb:stop",
