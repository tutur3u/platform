{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": false
  },
  "github": {
    "enabled": false
  },
  "crons": [
    {
      "path": "/api/cron/discord/daily-report",
      "schedule": "0 16 * * *"
    },
    {
      "path": "/api/cron/payment/products",
      "schedule": "0 */12 * * *"
    },
    {
      "path": "/api/cron/inventory/polar-product-sync",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/process-notification-batches",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/process-post-email-queue",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/process-topic-announcement-queue",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/calendar/provider-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/calendar/smart-schedule",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/tasks/deadline-reminders",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron/infrastructure/sample-resources",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/infrastructure/docker-recovery-alerts",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/infrastructure/sync-trust-cache",
      "schedule": "*/10 * * * *"
    }
  ]
}
