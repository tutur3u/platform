{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && bun turbo:local run build --filter=@tuturuuu/web",
  "installCommand": "cd ../.. && bun install --frozen-lockfile --minimum-release-age=0",
  "git": {
    "deploymentEnabled": false
  },
  "github": {
    "enabled": false
  },
  "crons": [
    {
      "path": "/api/cron/process-notification-batches",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/process-post-email-queue",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/process-report-automation",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/process-topic-announcement-queue",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/tasks/deadline-reminders",
      "schedule": "0 */4 * * *"
    }
  ]
}
