{
  "name": "@tuturuuu/qr",
  "version": "0.1.2",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsgo-build.js --build",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7819} --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7819 --turbopack"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "postcss": "^8.5.14",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "qr.tuturuuu",
    "script": "dev:app"
  }
