{
  "name": "@tuturuuu/nova",
  "version": "0.18.3",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsc-build.js --build",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7805} --turbopack",
    "devx": "bun sb:stop && bun sb:start && bun dev",
    "devrs": "bun sb:stop && bun sb:start && bun sb:reset && bun dev",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7805 --turbopack",
    "test": "vitest run",
    "test:watch": "vitest",
    "stop": "cd ../database && bun sb:stop",
    "sb:status": "cd ../database && bun sb:status",
    "sb:start": "cd ../database && bun sb:start",
    "sb:stop": "cd ../database && bun sb:stop",
    "sb:sync": "cd ../database && bun sb:sync",
    "sb:reset": "cd ../database && bun sb:reset",
    "sb:diff": "cd ../database && bun sb:diff",
    "sb:new": "cd ../database && bun sb:new",
    "sb:up": "cd ../database && bun sb:up",
    "sb:typegen": "cd ../database && bun sb:typegen",
    "ui:add": "bunx shadcn-ui@latest add",
    "ui:diff": "bunx shadcn-ui@latest diff"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@formatjs/intl-localematcher": "^0.8.10",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@tuturuuu/ai": "workspace:*",
    "@tuturuuu/auth": "workspace:*",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/supabase": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "@upstash/qstash": "^2.11.1",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.40.0",
    "jotai": "^2.20.1",
    "juice": "^12.1.1",
    "lodash": "4.18.1",
    "moment": "^2.30.1",
    "negotiator": "^1.0.0",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "sharp": "^0.35.2",
    "use-debounce": "^10.1.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/react": "^16.3.2",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/canvas-confetti": "^1.9.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260623.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "nova.tuturuuu",
    "script": "dev:app"
  }
}
