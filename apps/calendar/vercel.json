{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": true
  },
  "github": {
    "enabled": true
  },
  "crons": [
    {
      "path": "/api/cron/calendar/provider-sync",
