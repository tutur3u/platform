# Required environment variables
# for both development and production
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
TUTURUUU_APP_COORDINATION_SECRET=YOUR_APP_COORDINATION_SECRET

# Workspace end-to-end-encryption master key. REQUIRED for the calendar app to
# decrypt e2ee event fields (title/description/location) — its events API route
# decrypts inline. MUST be the SAME value as apps/web's ENCRYPTION_MASTER_KEY.
# Without it, events are returned still-encrypted and render as garbled strings.
# Provision it in the calendar Vercel project (Preview + Production).
ENCRYPTION_MASTER_KEY=YOUR_ENCRYPTION_MASTER_KEY

# Central web app port (used for API proxy fallback)
CENTRAL_PORT=7803

# Optional API keys
OPENAI_API_KEY=YOUR_OPENAI_API_KEY 
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=YOUR_GOOGLE_GENERATIVE_AI_API_KEY

# Google Vertex AI credentials
GOOGLE_VERTEX_PROJECT=YOUR_GOOGLE_VERTEX_PROJECT
GOOGLE_VERTEX_LOCATION=YOUR_GOOGLE_VERTEX_LOCATION
GOOGLE_APPLICATION_CREDENTIALS=YOUR_GOOGLE_APPLICATION_CREDENTIALS

# Google Calendar API credentials
# NOTE: register https://calendar.tuturuuu.com/api/v1/calendar/auth/callback
# (and the local dev equivalent) as an authorized redirect URI now that the
# calendar OAuth routes are served by this app instead of the central web app.
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI=YOUR_GOOGLE_REDIRECT_URI

# Microsoft Calendar (Graph) API credentials
MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=YOUR_MICROSOFT_CLIENT_SECRET
MICROSOFT_REDIRECT_URI=YOUR_MICROSOFT_REDIRECT_URI
MICROSOFT_TENANT_ID=YOUR_MICROSOFT_TENANT_ID

# Calendar cron + internal trigger auth (for the migrated calendar API routes:
# cron/calendar/*, calendar/sync, calendar/schedule, calendar/auto-schedule)
CRON_SECRET=YOUR_CRON_SECRET
VERCEL_CRON_SECRET=YOUR_VERCEL_CRON_SECRET
INTERNAL_TRIGGER_SECRET_KEY=YOUR_INTERNAL_TRIGGER_SECRET_KEY

# Central web app URL (internal API origin for the non-calendar routes that
# still proxy to the platform app, e.g. tasks/habits/boards/encryption)
WEB_APP_URL=YOUR_WEB_APP_URL
NEXT_PUBLIC_WEB_APP_URL=YOUR_WEB_APP_URL

# AWS Credentials
AWS_REGION=YOUR_AWS_REGION
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET
SOURCE_NAME=YOUR_SOURCE_NAME
SOURCE_EMAIL=YOUR_SOURCE_EMAIL
