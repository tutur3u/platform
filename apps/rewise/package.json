{
  "name": "@tuturuuu/rewise",
  "version": "0.14.0",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsgo-build.js --build",
    "dev": "portless",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7804} --turbopack",
    "devx": "bun sb:stop && bun sb:start && bun dev",
    "devrs": "bun sb:stop && bun sb:start && bun sb:reset && bun dev",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7804 --turbopack",
    "stop": "cd ../database && bun sb:stop",
    "sb:status": "cd ../database && bun sb:status",
    "sb:start": "cd ../database && bun sb:start",
    "sb:stop": "cd ../database && bun sb:stop",
    "sb:sync": "cd ../database && bun sb:sync",
    "sb:reset": "cd ../database && bun sb:reset",
    "sb:diff": "cd ../database && bun sb:diff",
    "sb:new": "cd ../database && bun sb:new",
    "sb:up": "cd ../database && bun sb:up",
    "sb:typegen": "cd ../database && bun sb:typegen",
    "ui:add": "bunx shadcn-ui@latest add",
    "ui:diff": "bunx shadcn-ui@latest diff"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.3.0",
    "@emotion/react": "^11.14.0",
    "@emotion/server": "^11.11.0",
    "@formatjs/intl-localematcher": "^0.8.8",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-table": "^8.21.3",
    "@tuturuuu/ai": "workspace:*",
    "@tuturuuu/apis": "workspace:*",
    "@tuturuuu/auth": "workspace:*",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/offline": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/supabase": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "@upstash/qstash": "^2.10.1",
    "cookies-next": "^6.1.1",
    "date-fns": "^4.2.1",
    "dayjs": "^1.11.20",
    "lodash": "^4.18.1",
    "mermaid": "^11.15.0",
    "moment": "^2.30.1",
    "negotiator": "^1.0.0",
    "next": "^16.2.6",
    "next-intl": "^4.11.2",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-intersection-observer": "^10.0.3",
    "react-textarea-autosize": "^8.5.9",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sanitize-filename": "^1.6.4",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.11",
    "@testing-library/react": "^16.3.2",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "rewise.tuturuuu",
    "script": "dev:app"
  }
}
