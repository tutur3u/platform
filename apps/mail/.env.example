# Shared app authentication and Supabase service access
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Email Service outbound transport
MAIL_CLOUDFLARE_ACCOUNT_ID=
MAIL_CLOUDFLARE_API_TOKEN=

# Cloudflare Email Routing signed ingestion
MAIL_CLOUDFLARE_INGEST_SECRET=

# Private Cloudflare R2 storage used by the Mail app server
MAIL_R2_ACCOUNT_ID=
MAIL_R2_ACCESS_KEY_ID=
MAIL_R2_SECRET_ACCESS_KEY=
MAIL_R2_BUCKET_NAME=tuturuuu-mail
# Optional override for R2-compatible development or test storage.
MAIL_R2_ENDPOINT=

# Existing SES inbound transport
MAIL_SES_INBOUND_TOPIC_ARN=
MAIL_SES_INBOUND_BUCKET=
MAIL_SES_INBOUND_KEY_PREFIX=
MAIL_SES_REGION=
