{
  "name": "@tuturuuu/mail",
  "version": "0.7.0",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsc-build.js --build",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7820} --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7820 --turbopack",
    "sb:status": "cd ../database && bun sb:status",
    "sb:start": "cd ../database && bun sb:start",
    "sb:stop": "cd ../database && bun sb:stop",
    "sb:up": "cd ../database && bun sb:up",
    "sb:typegen": "cd ../database && bun sb:typegen"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "mail.tuturuuu",
    "script": "dev:app"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.12",
    "@aws-sdk/client-s3": "3.1087.0",
    "@formatjs/intl-localematcher": "^0.8.12",
    "@tanstack/react-query": "5.101.2",
    "@tiptap/extension-image": "3.27.4",
    "@tiptap/extension-link": "3.27.4",
    "@tiptap/extension-placeholder": "3.27.4",
    "@tiptap/react": "3.28.0",
    "@tiptap/starter-kit": "3.27.4",
    "@tuturuuu/ai": "workspace:*",
    "@tuturuuu/auth": "workspace:*",
    "@tuturuuu/email-service": "workspace:*",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/offline": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/supabase": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "ai": "^7.0.22",
    "cookies-next": "^6.1.1",
    "dayjs": "1.11.21",
    "isomorphic-dompurify": "^3.18.0",
    "negotiator": "^1.0.0",
    "next": "^16.3.0-preview.6",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "nuqs": "^2.9.0",
    "postal-mime": "2.7.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query-devtools": "5.101.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "postcss": "^8.5.19",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
