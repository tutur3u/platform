{
  "name": "@tuturuuu/mail",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsgo-build.js --build",
    "dev": "portless",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7820} --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7820 --turbopack",
    "sb:status": "cd ../database && bun sb:status",
    "sb:start": "cd ../database && bun sb:start",
    "sb:stop": "cd ../database && bun sb:stop",
    "sb:up": "cd ../database && bun sb:up",
    "sb:typegen": "cd ../database && bun sb:typegen"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "mail.tuturuuu",
    "script": "dev:app"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.9",
    "@tanstack/react-query": "5.101.0",
    "@tuturuuu/auth": "workspace:*",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/offline": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/supabase": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "cookies-next": "^6.1.1",
    "dayjs": "1.11.21",
    "negotiator": "^1.0.0",
    "next": "^16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "postcss": "^8.5.15",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
