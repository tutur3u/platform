{
  "name": "@tuturuuu/apps",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsc-build.js --build",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7818} --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7818 --turbopack"
  },
  "dependencies": {
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260614.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "postcss": "^8.5.14",
    "typescript": "7.0.1-rc"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "apps.tuturuuu",
    "script": "dev:app"
  }
}
