# Required environment variables
# for both development and production
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_SECRET_KEY=YOUR_SUPABASE_SECRET_KEY
TUTURUUU_APP_COORDINATION_SECRET=YOUR_APP_COORDINATION_SECRET
POLAR_ACCESS_TOKEN=YOUR_POLAR_ACCESS_TOKEN
POLAR_SANDBOX=false
POLAR_WEBHOOK_SECRET=YOUR_POLAR_WEBHOOK_SECRET
CRON_SECRET=YOUR_CRON_SECRET

# Optional infrastructure log drain for Pay cron observability
PLATFORM_LOG_DRAIN_DATABASE_URL=YOUR_POSTGRES_CONNECTION_STRING
PLATFORM_LOG_DRAIN_ENABLED=false
PLATFORM_LOG_DRAIN_PROJECT_ID=pay

# Central web app port (used for API proxy fallback)
CENTRAL_PORT=7803
