{
  "name": "@tuturuuu/hive",
  "version": "0.4.0",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsc-build.js --build",
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7814} --turbopack",
    "devx": "bun sb:stop && bun sb:start && bun dev",
    "devrs": "bun sb:stop && bun sb:start && bun sb:reset && bun dev",
    "build": "next build --turbopack",
    "build:docker": "node ../../scripts/run-hive-docker-next-build.js",
    "serve:hive": "NODE_OPTIONS='--max-http-header-size=65536 --experimental-require-module' next start -p 7814",
    "start": "NODE_OPTIONS='--max-http-header-size=65536' next start -p 7814",
    "preview": "next build --turbopack && NODE_OPTIONS='--max-http-header-size=65536' next start -p 7814",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:watch": "vitest",
    "stop": "cd ../database && bun sb:stop",
    "sb:status": "cd ../database && bun sb:status",
    "sb:start": "cd ../database && bun sb:start",
    "sb:stop": "cd ../database && bun sb:stop",
    "sb:sync": "cd ../database && bun sb:sync",
    "sb:reset": "cd ../database && bun sb:reset",
    "sb:diff": "cd ../database && bun sb:diff",
    "sb:new": "cd ../database && bun sb:new",
    "sb:up": "cd ../database && bun sb:up",
    "sb:typegen": "cd ../database && bun sb:typegen"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.10",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.101.2",
    "@tuturuuu/ai": "workspace:*",
    "@tuturuuu/auth": "workspace:*",
    "@tuturuuu/hive-ui": "workspace:*",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/offline": "workspace:*",
    "@tuturuuu/realtime": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/supabase": "workspace:*",
    "@tuturuuu/types": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "@tuturuuu/vercel": "workspace:*",
    "@xyflow/react": "^12.11.1",
    "negotiator": "^1.0.0",
    "next": "^16.3.0-preview.5",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@testing-library/react": "^16.3.2",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@typescript/native-preview": "7.0.0-dev.20260630.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.9"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "hive.tuturuuu",
    "script": "dev:app"
  }
}
