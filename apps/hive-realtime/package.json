{
  "name": "@tuturuuu/hive-realtime",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/portless-safe-dev.js",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- bun --watch src/index.ts",
    "serve:hive-realtime": "bun run start",
    "start": "bun src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --project tsconfig.json"
  },
  "dependencies": {
    "@tuturuuu/realtime": "workspace:*",
    "jose": "^6.2.3",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tuturuuu/typescript-config": "workspace:*",
    "bun-types": "^1.3.14",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  },
  "packageManager": "bun@1.3.14",
  "portless": {
    "name": "realtime.hive.tuturuuu",
    "script": "dev:app"
  }
}
