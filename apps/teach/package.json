{
  "name": "@tuturuuu/teach",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "type-check": "node ../../scripts/run-tsgo-build.js --build",
    "dev": "portless",
    "dev:app": "node ../../scripts/portless-dev-banner.js -- next dev -p ${PORT:-7813} --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "preview": "next build --turbopack && next start -p 7813 --turbopack"
  },
  "packageManager": "bun@1.3.14",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@formatjs/intl-localematcher": "^0.8.9",
    "@gsap/react": "^2.1.2",
    "@tanstack/react-query": "^5.100.11",
    "@tuturuuu/auth": "workspace:*",
    "@tuturuuu/icons": "workspace:*",
    "@tuturuuu/internal-api": "workspace:*",
    "@tuturuuu/satellite": "workspace:*",
    "@tuturuuu/supabase": "workspace:*",
    "@tuturuuu/ui": "workspace:*",
    "@tuturuuu/utils": "workspace:*",
    "gsap": "^3.15.0",
    "negotiator": "^1.0.0",
    "next": "^16.2.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "use-debounce": "^10.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tuturuuu/typescript-config": "workspace:*",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3"
  },
  "portless": {
    "name": "teach.tuturuuu",
    "script": "dev:app"
  }
}
